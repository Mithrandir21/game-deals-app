# Gradle files
.gradle/
build/
.kotlin/

# Local configuration file (sdk path, etc)
local.properties

# iOS local secrets (real xcconfig is gitignored; commit only the .template).
# Xcode's project-wizard wiring may place the active xcconfig at iosApp/Secrets.xcconfig
# (next to iosApp.xcodeproj) instead of iosApp/Configuration/ — gitignore both paths.
iosApp/Secrets.xcconfig
iosApp/Configuration/Secrets.xcconfig

# Log/OS Files
*.log

# Android Studio generated files and folders
captures/
release/
.externalNativeBuild/
.cxx/
*.apk
output.json

# IntelliJ
*.iml
.idea/
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml

# Keystore files
*.jks
*.keystore

# Android Profiling
*.hprof

# Claude Ignores
/.claude/worktrees/
/.claude/scratch/
